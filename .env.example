# ============================================================
# Copy this file to .env and fill in your real values
# .env should NEVER be committed to git
# ============================================================

# Anthropic API key (required for LLM calls in Phases 4+)
ANTHROPIC_API_KEY=
# OpenAI API key (required for multi-LLM strategy)
OPENAI_API_KEY=
# Groq API key (optional — for ultra-fast Llama inference)
# Get a free key at https://console.groq.com → API Keys
GROQ_API_KEY=

# Email for OpenAlex polite pool (recommended, gives better rate limits)
# Use your real email - they don't spam you
OPENALEX_EMAIL=your-email@example.com

# Optional: OpenAlex API key for higher rate limits
# Get one for free at https://openalex.org/settings/api
OPENALEX_API_KEY=

# Optional: Voyage AI for embeddings (Phase later)
VOYAGE_API_KEY=

# ============================================================
# Email delivery (optional — used by export_to_pdf.py --email)
# ============================================================

# Your Gmail address (the one that sends the report)
EMAIL_SENDER=

# Gmail App Password — NOT your regular Gmail password!
# How to generate one:
#   1. Enable 2-Step Verification on your Google Account
#      https://myaccount.google.com/security
#   2. Go to: Google Account → Security → 2-Step Verification → App passwords
#   3. Select app: "Mail", device: "Windows Computer" (or any name)
#   4. Google generates a 16-character password → paste it here (no spaces)
EMAIL_PASSWORD=

# Default recipient (used when --email flag is not provided on the CLI).
# Leave empty to require --email to be specified explicitly each time.
EMAIL_RECEIVER=